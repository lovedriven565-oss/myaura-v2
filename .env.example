# ==========================================
# MyAURA V2 Environment Configuration
# ==========================================

# --- Telegram Integration ---
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
APP_URL="https://myaura.by"

# --- AI Provider (Vertex AI / Gemini) ---
# Set USE_VERTEX_AI="true" to use Google Cloud Vertex AI (Production). 
# Set USE_VERTEX_AI="false" to use standard Gemini API (Dev/Fallback).
USE_VERTEX_AI="false"

# [A. Gemini Fallback Configuration]
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# [B. Vertex AI Configuration]
# When USE_VERTEX_AI="true", you MUST provide the following for the GCP SDK:
# GOOGLE_GENAI_USE_VERTEXAI="true"
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_CLOUD_LOCATION="us-central1"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/gcp/service-account.json"

# --- Cloudflare R2 Storage ---
R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="myaura-bucket"
R2_PUBLIC_BASE_URL="https://pub-xxxx.r2.dev"
# R2 S3 API endpoint. For EU jurisdiction buckets use: https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
# Default (if not set): https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
# R2_S3_ENDPOINT="https://YOUR_ACCOUNT_ID.eu.r2.cloudflarestorage.com"

# --- Supabase Database ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --- Admin / Debug ---
ADMIN_SECRET="your-admin-secret-here"
ENABLE_QUALITY_VALIDATION="false"

# --- Quality Gate Configuration ---
# QUALITY_GATE_PASS_THRESHOLD=45
# QUALITY_GATE_REROLL_ENABLED=true
# QUALITY_GATE_MAX_REROLLS=1
# QUALITY_GATE_MULTIMODAL=true

# --- Input Curation Configuration ---
# CURATION_MIN_FILE_SIZE=30000
# CURATION_MAX_FILE_SIZE=10485760
# CURATION_TARGET_SELECTION=8
# CURATION_MIN_ACCEPTABLE=3

# --- Business Logic & Retention (in minutes) ---
RETENTION_ORIGINAL_MINUTES=1440
RETENTION_PREMIUM_REF_MINUTES=4320
RETENTION_RESULT_MINUTES=10080
