# ==========================================
# MyAURA V2 Environment Configuration
# ==========================================

# --- Telegram Integration ---
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
APP_URL="https://myaura.by"

# --- AI Provider (Vertex AI / Gemini) ---
# Set USE_VERTEX_AI="true" to use Google Cloud Vertex AI (Production). 
# Set USE_VERTEX_AI="false" to use standard Gemini API (Dev/Fallback).
USE_VERTEX_AI="false"

# [A. Gemini Fallback Configuration]
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# [B. Vertex AI Configuration]
# When USE_VERTEX_AI="true", you MUST provide the following for the GCP SDK:
# GOOGLE_GENAI_USE_VERTEXAI="true"
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_CLOUD_LOCATION="us-central1"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/gcp/service-account.json"

# --- Cloudflare R2 Storage ---
R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="myaura"
R2_PUBLIC_BASE_URL="https://pub-xxxx.r2.dev"
# R2 S3 API endpoint. Must match the jurisdiction of your bucket!
#   default / automatic : https://<ACCOUNT_ID>.r2.cloudflarestorage.com     (Dashboard default)
#   EU jurisdiction     : https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
#   FedRAMP             : https://<ACCOUNT_ID>.fedramp.r2.cloudflarestorage.com
# If not set, code defaults to the automatic (default) jurisdiction.
# R2_S3_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"

# --- Supabase Database ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --- Admin / Debug ---
ADMIN_SECRET="your-admin-secret-here"
ENABLE_QUALITY_VALIDATION="false"

# --- Quality Gate Configuration ---
# QUALITY_GATE_PASS_THRESHOLD=45
# QUALITY_GATE_REROLL_ENABLED=true
# QUALITY_GATE_MAX_REROLLS=1
# QUALITY_GATE_MULTIMODAL=true

# --- Input Curation Configuration ---
# CURATION_MIN_FILE_SIZE=30000
# CURATION_MAX_FILE_SIZE=10485760
# CURATION_TARGET_SELECTION=8
# CURATION_MIN_ACCEPTABLE=3

# --- Business Logic & Retention (in minutes) ---
RETENTION_ORIGINAL_MINUTES=1440
RETENTION_PREMIUM_REF_MINUTES=4320
RETENTION_RESULT_MINUTES=10080

# --- Security: Telegram initData validation ---
# STRONGLY RECOMMENDED in production: INIT_DATA_STRICT="true"
# When true, ALL /api/* requests must include a valid, signed x-telegram-init-data header.
# telegramId is derived server-side from the signature — client-provided ids are ignored.
INIT_DATA_STRICT="true"

# --- Server runtime ---
PORT=3000
# Optional extra CORS origins (comma-separated). https://myaura.by is always allowed in prod.
# CORS_ORIGINS="https://staging.myaura.by"

# --- Telegram bot (server-side) ---
# Set to "false" on any environment that should NOT poll the bot (local dev, staging, etc.)
# to avoid 409 Conflict with the production bot instance.
ENABLE_TELEGRAM_BOT="true"

# --- Vertex AI model routing (v3.2) ---
# These names take precedence over FREE_MODEL_ID / PREMIUM_MODEL_ID.
VERTEX_AI_MODEL_FREE="gemini-3.1-flash-image-preview"
VERTEX_AI_MODEL_PREMIUM="gemini-3-pro-image-preview"
# Location used by @google/genai in Vertex mode (global endpoint supported).
VERTEX_LOCATION="global"

# --- Free flow v2 (multi-reference for free tier) ---
# When true: users upload up to 5 reference photos for the free preview.
FREE_MULTI_REF_V2_ENABLED="true"

# --- Frontend build-time (Vite) ---
# Bot username used to construct referral share links (t.me/<username>?startapp=...).
VITE_BOT_USERNAME="myaura_bot"
# Must match server FREE_MULTI_REF_V2_ENABLED so the UI shows "до 5 фото".
VITE_FREE_MULTI_REF_V2_ENABLED="true"

# --- Generation queue ---
# Minimum ms between task starts in the global generation queue.
INTER_REQUEST_DELAY_MS=6000
# Admission control: max outstanding tasks before /generate is rejected with 429.
MAX_QUEUE_DEPTH=200
